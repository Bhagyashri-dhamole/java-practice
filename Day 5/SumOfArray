import java.util.Scanner;
public class SumOfArray
{
	public static void main(String[] args) {
		Scanner Sc = new Scanner(System.in);
		int n = Sc.nextInt();
		int array[] = new int [n];
		int sum = 0;
		for(int i = 0; i <= array.length-1;i++)
		{
			array[i] = Sc.nextInt();
		}
		for(int i = 0; i < array.length;i++)
		{
			sum = sum + array[i];
		}
		System.out.println(sum);
	}
}
