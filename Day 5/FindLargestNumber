import java.util.Scanner;
public class FindLargestNumber
{
	public static void main(String[] args) {
		Scanner Sc = new Scanner(System.in);
		int n = Sc.nextInt();
		int arr[] = new int[n];
		for(int i = 0;i <= arr.length-1;i++)
			{
				arr[i] = Sc.nextInt();
			}
			int largest = arr[0];
			for(int i = 0;i <= arr.length-1;i++)
			{
				if(arr[i] > largest)
				{
					largest = arr[i];
				}
			}
			System.out.println(largest);
	}
}
